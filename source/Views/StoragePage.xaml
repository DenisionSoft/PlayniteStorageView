<UserControl x:Class="PlayniteStorageView.Views.StoragePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteStorageView.ViewModels"
             xmlns:conv="clr-namespace:PlayniteStorageView.Views.Converters"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             d:DataContext="{d:DesignInstance Type=vm:StoragePageViewModel}">

    <UserControl.Resources>
        <!-- Make all bare TextBlocks pick up Playnite's themed foreground/font, so
             "Storage" title, legend, captions etc. render in the theme's text color. -->
        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BaseTextBlockStyle}" />

        <conv:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter" />
        <conv:NullOrEmptyToCollapsedConverter x:Key="NullOrEmptyToCollapsedConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Bar segment colors. Hard-coded so they remain readable across all Playnite themes. -->
        <SolidColorBrush x:Key="StorageBarGamesBrush" Color="#FF4A90E2" />
        <SolidColorBrush x:Key="StorageBarOtherBrush" Color="#FFB8860B" />
        <SolidColorBrush x:Key="StorageBarFreeBrush"  Color="#FF3D8B40" />

        <Style x:Key="LegendSwatchStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="RadiusX" Value="2" />
            <Setter Property="RadiusY" Value="2" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: Header (title + refresh) -->
            <RowDefinition Height="Auto" />  <!-- 1: Drive picker + counts -->
            <RowDefinition Height="Auto" />  <!-- 2: Stacked bar -->
            <RowDefinition Height="Auto" />  <!-- 3: Legend -->
            <RowDefinition Height="Auto" />  <!-- 4: Unknown-size note -->
            <RowDefinition Height="*" />     <!-- 5: Game list -->
        </Grid.RowDefinitions>

        <!-- ============== Row 0: Header ==============
             Top margin keeps the Refresh button clear of Playnite's window control buttons. -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,12,0,15">
            <TextBlock DockPanel.Dock="Left"
                       Text="{DynamicResource LOCStorageViewPageTitle}"
                       FontSize="24" FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Button DockPanel.Dock="Right"
                    Content="{DynamicResource LOCStorageViewRefresh}"
                    Command="{Binding RefreshCommand}"
                    Padding="14,4" VerticalAlignment="Center" />

            <ProgressBar DockPanel.Dock="Right"
                         Width="120" Height="6" Margin="0,0,12,0"
                         IsIndeterminate="True"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </DockPanel>

        <!-- ============== Row 1: Drive picker + per-drive counts ============== -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{DynamicResource LOCStorageViewDriveLabel}"
                       VerticalAlignment="Center" FontSize="14" />

            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Drives}"
                      SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                      VerticalAlignment="Center" FontSize="14">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                        DataContext="{Binding SelectedDrive}">
                <TextBlock Text="{DynamicResource LOCStorageViewGamesInstalledLabel}" />
                <TextBlock Margin="6,0,18,0" FontWeight="SemiBold"
                           Text="{Binding Games.Count, FallbackValue=0}" />
                <TextBlock Text="{DynamicResource LOCStorageViewUsedByGamesLabel}" />
                <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                           Text="{Binding Usage.GamesDisplay, FallbackValue=—}" />
            </StackPanel>
        </Grid>

        <!-- ============== Row 2: Stacked bar ============== -->
        <Border Grid.Row="2" BorderThickness="{DynamicResource PopupBorderThickness}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                CornerRadius="3" SnapsToDevicePixels="True"
                Margin="0,0,0,8">
            <!-- The 3 column widths are set in code-behind whenever SelectedDrive changes,
                 because ColumnDefinitions are not part of the visual tree and DataContext
                 doesn't flow into them. See StoragePage.xaml.cs (RebuildBar). -->
            <Grid x:Name="BarGrid" Height="26" SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*" />
                    <ColumnDefinition Width="0*" />
                    <ColumnDefinition Width="0*" />
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" Fill="{StaticResource StorageBarGamesBrush}"
                           ToolTip="{Binding SelectedDrive.Usage.GamesDisplay, FallbackValue=—}" />
                <Rectangle Grid.Column="1" Fill="{StaticResource StorageBarOtherBrush}"
                           ToolTip="{Binding SelectedDrive.Usage.OtherDisplay, FallbackValue=—}" />
                <Rectangle Grid.Column="2" Fill="{StaticResource StorageBarFreeBrush}"
                           ToolTip="{Binding SelectedDrive.Usage.FreeDisplay, FallbackValue=—}" />
            </Grid>
        </Border>

        <!-- ============== Row 3: Legend ============== -->
        <DockPanel Grid.Row="3" Margin="0,0,0,4" DataContext="{Binding SelectedDrive}">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="20,0,0,0">
                <TextBlock Text="{DynamicResource LOCStorageViewTotalLegend}" Opacity="0.7" />
                <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                           Text="{Binding Usage.TotalDisplay, FallbackValue=—}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Rectangle Style="{StaticResource LegendSwatchStyle}"
                               Fill="{StaticResource StorageBarGamesBrush}" />
                    <TextBlock Text="{DynamicResource LOCStorageViewGamesLegend}" Opacity="0.7" />
                    <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                               Text="{Binding Usage.GamesDisplay, FallbackValue=—}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Rectangle Style="{StaticResource LegendSwatchStyle}"
                               Fill="{StaticResource StorageBarOtherBrush}" />
                    <TextBlock Text="{DynamicResource LOCStorageViewOtherLegend}" Opacity="0.7" />
                    <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                               Text="{Binding Usage.OtherDisplay, FallbackValue=—}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Rectangle Style="{StaticResource LegendSwatchStyle}"
                               Fill="{StaticResource StorageBarFreeBrush}" />
                    <TextBlock Text="{DynamicResource LOCStorageViewFreeLegend}" Opacity="0.7" />
                    <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                               Text="{Binding Usage.FreeDisplay, FallbackValue=—}" />
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <!-- ============== Row 4: "N games have no size data" ============== -->
        <TextBlock Grid.Row="4" Margin="0,8,0,4"
                   FontStyle="Italic" Opacity="0.6"
                   Text="{Binding SelectedDrive.UnknownSizeCaption}"
                   Visibility="{Binding SelectedDrive.UnknownSizeGameCount, Converter={StaticResource ZeroToCollapsedConverter}}" />

        <!-- ============== Row 5: Game list ============== -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <!-- Empty state -->
            <TextBlock Text="{DynamicResource LOCStorageViewEmpty}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0.6" FontSize="14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDrive.Games.Count, FallbackValue=0}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- The list -->
            <ListView x:Name="GameList"
                      ItemsSource="{Binding SelectedDrive.Games}"
                      BorderThickness="{DynamicResource PopupBorderThickness}"
                      BorderBrush="{DynamicResource NormalBorderBrush}"
                      SelectionMode="Single"
                      GridViewColumnHeader.Click="GameList_HeaderClicked"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.Style>
                    <Style TargetType="ListView" BasedOn="{StaticResource {x:Type ListView}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDrive.Games.Count, FallbackValue=0}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                        <!-- ContextMenu lives in its own popup visual tree and doesn't inherit the
                             ListView's DataContext (which is the ViewModel). Stash the VM on each
                             ListViewItem's Tag so the menu can reach commands via PlacementTarget.Tag. -->
                        <Setter Property="Tag"
                                Value="{Binding DataContext,
                                                RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource LOCStorageViewOpenInstallFolder}"
                                              Command="{Binding PlacementTarget.Tag.OpenInstallFolderCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <!-- Icon -->
                        <GridViewColumn Width="40">
                            <GridViewColumnHeader Tag="noSort" />
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding IconPath, IsAsync=True}"
                                           Width="24" Height="24"
                                           Visibility="{Binding IconPath, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Name -->
                        <GridViewColumn Width="320">
                            <GridViewColumnHeader Content="{DynamicResource LOCStorageViewColName}" Tag="Name" />
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Name}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Source -->
                        <GridViewColumn Width="140">
                            <GridViewColumnHeader Content="{DynamicResource LOCStorageViewColSource}" Tag="SourceName" />
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceName}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Size (right-aligned) -->
                        <GridViewColumn Width="110">
                            <GridViewColumnHeader Content="{DynamicResource LOCStorageViewColSize}" Tag="InstallSizeBytes" />
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding InstallSizeDisplay}"
                                               HorizontalAlignment="Right" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Install dir -->
                        <GridViewColumn Width="500">
                            <GridViewColumnHeader Content="{DynamicResource LOCStorageViewColPath}" Tag="InstallDirectory" />
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding InstallDirectory}" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding InstallDirectory}" Opacity="0.85" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
